package pages;

import java.io.FileNotFoundException;
import java.io.IOException;
import java.time.Duration;
import java.util.List;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;

import configReader.ObjectReader;
import utility.ExcelUtils;
import utility.FindElementUtils;
import utility.WaitUtils;

public class ProductPage {
	
	WebDriver driver = null;
	FindElementUtils findUtil = null;
	ObjectReader objReader = null;
	WaitUtils waitUtil;
	ExcelUtils excelUtil;
	
	// XPath strings for elements that don't change
	String relevanceXPath = "//li[normalize-space()='Relevance']";
	String goBtnXPath = "//*[@id=\"content_wrapper\"]/div[7]/div[3]/div/div[1]/div[2]/div[2]/div[3]/div/div[5]";

	public ProductPage(WebDriver driver) throws IOException {
		this.driver = driver;
		
		// Initializing all our tools and property readers
		this.objReader = new ObjectReader();
		this.findUtil = new FindElementUtils(driver);
		this.excelUtil = new ExcelUtils();
		this.waitUtil = new WaitUtils(driver, Duration.ofSeconds(1));
	}
	
	// Method to click the sort dropdown and select 'Relevance'
	public WebElement selectSort() {
		WebElement sortBy = findUtil.findElementByClass(objReader.getSortByClass());
		waitUtil.explicitWait(); // Small pause for stability
		sortBy.click();
		waitUtil.explicitWait(); 
		WebElement relevance = findUtil.findElementByXpath(relevanceXPath);
		relevance.click();
		return sortBy;
	}
	
	// Setting the minimum price filter to 500
	public WebElement setMinimumValue(String mini) {
		WebElement minVal = findUtil.findElementByName("fromVal");
		waitUtil.explicitWait();
		minVal.clear(); // Clearing the box before typing
		waitUtil.explicitWait();
		minVal.sendKeys(mini);
		return minVal;
	}
	
	// Setting the maximum price filter to 900
	public WebElement setMaximumValue(String maxi) {
		WebElement maxVal = findUtil.findElementByName("toVal");
		waitUtil.explicitWait();
		maxVal.clear();
		waitUtil.explicitWait();
		maxVal.sendKeys(maxi);
		return maxVal;
	}
	
	// Clicking the Go button and checking if the filter actually applied
	public boolean clickGoBtn() {
		waitUtil.explicitWait();
		WebElement goBtn = findUtil.findElementByXpath(goBtnXPath);
		goBtn.click();
		
		WebElement maxVal = findUtil.findElementByName("toVal");
		String exp = maxVal.getAttribute("value");
		return exp.equals("900");
	}
	
	// Collecting the first 5 results and saving them to an Excel sheet
	public void printResult() throws InterruptedException, FileNotFoundException, IOException {
		waitUtil.explicitWait();
		
		// Getting lists of all titles and prices shown on the page
		List<WebElement> productName = findUtil.findElementsByClass("product-title");
		List<WebElement> productPrice = findUtil.findElementsByCssSelector("span.product-price");
		
		// Creating a 2D array to hold 5 rows of data (S.No, Title, Price)
		String data[][] = new String[5][3];
		
		for (int i = 0; i < 5; i++) {
			data[i][0] = String.valueOf(i + 1);
			data[i][1] = productName.get(i).getText();
			data[i][2] = productPrice.get(i).getText();
		}
		
		// Calling our utility to write this data and then print it to console
		excelUtil.writeToExcel(objReader.getExcelPath(), data);
		excelUtil.readFromExcel(objReader.getExcelPath());
	}
}