package utility;

import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;

public class FindElementUtils {
	
	WebDriver driver = null;

	// Constructor to bring in the driver from our main test
	public FindElementUtils(WebDriver driver) {
		this.driver = driver;
	}
	
	// Helper method to find an element using its ID
	public WebElement findElementById(String id) {
		return driver.findElement(By.id(id));
	}
	
	// Helper method to find an element using its Name attribute
	public WebElement findElementByName(String n) {
		return driver.findElement(By.name(n));
	}
	
	// Helper method to find an element using its Class name
	public WebElement findElementByClass(String classN) {
		return driver.findElement(By.className(classN));
	}

	// Helper method to find an element using an Xpath expression
	public WebElement findElementByXpath(String xp) {
		return driver.findElement(By.xpath(xp));
	}

	// Helper method to find an element using a CSS Selector
	public WebElement findElementByCssSelector(String cS) {
		return driver.findElement(By.cssSelector(cS));
	}
	
	// Helper method to find multiple element using its Name attribute
	public List<WebElement> findElementsByName(String n) {
		return driver.findElements(By.name(n));
	}
	
	// Helper method to find multiple element using its Class name
	public List<WebElement> findElementsByClass(String classN) {
		return driver.findElements(By.className(classN));
	}

	// Helper method to find multiple element using a CSS Selector
	public List<WebElement> findElementsByCssSelector(String cS) {
		return driver.findElements(By.cssSelector(cS));
	}
}