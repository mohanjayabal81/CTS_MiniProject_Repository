package tests;

import java.io.FileNotFoundException;
import java.io.IOException;
import java.util.Scanner;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.testng.Assert;
import org.testng.Reporter;
import org.testng.annotations.AfterClass;
import org.testng.annotations.BeforeClass;
import org.testng.annotations.Test;
import org.testng.asserts.SoftAssert;

import com.aventstack.extentreports.ExtentReports;
import com.aventstack.extentreports.ExtentTest;
import com.aventstack.extentreports.Status;
import com.aventstack.extentreports.reporter.ExtentSparkReporter;

import configReader.ObjectReader;
import implementation.BrowserImplementation;
import pages.HomePage;
import pages.ProductPage;
import utility.ScreenshotUtils;

public class SnapdealTest {
	
	// Defining all our objects and tools we will use across the tests
	WebDriver driver = null;
	ObjectReader objReader = null;
	HomePage homePage = null;
	ProductPage productPage=null;
	Scanner sc=null;
	ScreenshotUtils screenshotUtil=null;
	ExtentReports extent=null;
	ExtentTest test=null;
	

	@BeforeClass
	public void setUp() throws IOException {
		// 1. First, load the settings from our properties file
		this.objReader = new ObjectReader();
		
		// 2. Setup the HTML report so we can track pass/fail
		ExtentSparkReporter spark = new ExtentSparkReporter(objReader.getReportsPath());
		extent = new ExtentReports();
		extent.attachReporter(spark);
		
		// 3. Ask the user which browser they want to use today
		System.out.println("Enter your preferred browser(Chrome/Edge):");
		sc = new Scanner(System.in);
		String browser = sc.next();
		browser = browser.toLowerCase();
		
		// 4. Start the right browser based on the user's input
		switch (browser) {
			case "chrome":
				driver = new BrowserImplementation().getChromeDriver();
				break;
			case "edge":
				driver = new BrowserImplementation().getEdgeDriver();
				break;
			default:
				System.out.println("Please enter valid Web Browser Name");
				break;
		}
		
		// 5. Basic browser setup and opening the website
		driver.manage().window().maximize();
		driver.get(objReader.getURL("BASEURL"));
		
		// 6. Initialize our Page Objects and Utilities after the driver is ready
		homePage = new HomePage(driver);
		screenshotUtil = new ScreenshotUtils(objReader.getScreenshotPath());
		productPage = new ProductPage(driver);
	}

	@Test(priority = 0)
	public void testHomePage() {
		test = extent.createTest("Home Page Testing");
		try {
			// Verifying if the title of the landing page is correct
			Assert.assertTrue(homePage.verifyHomePageTitle());
			test.log(Status.PASS, "Home Page Verification Successful");
			test.addScreenCaptureFromPath(screenshotUtil.fullScreenShot(driver, "HomePage"));
		} catch (AssertionError e) {
			test.log(Status.FAIL, "Home Page Verification Failed");
			test.addScreenCaptureFromPath(screenshotUtil.fullScreenShot(driver, "HomePageError"));
		}
		Reporter.log("HomePage verified successfully");
	}

	@Test(priority = 1)
	public void testSeachProduct() {
		test = extent.createTest("Search Product Functionality Test");
		String expProduct = "Bluetooth Headphones";
		
		// Performing the search action and getting the element back
		WebElement searchProduct = homePage.searchProduct();
		String acProduct = searchProduct.getAttribute("value");
		
		try {
			// Checking if the text we typed is actually in the search box
			Assert.assertEquals(acProduct, expProduct);
			test.log(Status.PASS, "Search Product Functionality Passed");
			test.addScreenCaptureFromPath(screenshotUtil.elementScreenShot(searchProduct, "SearchProduct"));
			Reporter.log("Search Verified Successfully...");
		} catch (AssertionError e) {
			test.log(Status.FAIL, "Search Product Functionality Failed");
			test.addScreenCaptureFromPath(screenshotUtil.elementScreenShot(searchProduct, "SearchProductFail"));
		}
	}

	@Test(priority = 2, dependsOnMethods="testSeachProduct")
	public void testSelectSortBy() {
		test = extent.createTest("Sort By Functionality Test");
		String expSortBy = "Relevance";
		
		// Clicking the sort dropdown and checking the result
		WebElement sort = productPage.selectSort();
		String acSortBy = sort.getText();
		
		try {
			Assert.assertEquals(acSortBy, expSortBy);
			test.log(Status.PASS, "Sort By Relevance Verified Successfully...");
			test.addScreenCaptureFromPath(screenshotUtil.elementScreenShot(sort, "SortBy"));
			Reporter.log("Sort By Relevance Verified Successfully...");
		} catch (AssertionError e) {
			test.log(Status.FAIL, "Sort By Relevance Verification Failed...");
			test.addScreenCaptureFromPath(screenshotUtil.elementScreenShot(sort, "SortByFail"));
		}
	}

	@Test(priority = 3)
	public void testMinimumRange() {
		test = extent.createTest("Set Minimum Price");
		String expVal = "500";
		
		// Setting the price to 500 and verifying the box holds that value
		WebElement mini = productPage.setMinimumValue("500");
		try {
			Assert.assertEquals(mini.getAttribute("value"), expVal);
			test.log(Status.PASS, "Set Minimum Price Verified Successfully...");
			test.addScreenCaptureFromPath(screenshotUtil.elementScreenShot(mini, "MinimumValue"));
		} catch (AssertionError e) {
			test.log(Status.FAIL, "Set Minimum Price Failed...");
			test.addScreenCaptureFromPath(screenshotUtil.elementScreenShot(mini, "MinimumValueFail"));
		}
		Reporter.log("Minimum range value set verified...");
	}

	@Test(priority = 4)
	public void testMaximumRange() {
		test = extent.createTest("Set Maximum Price");
		String expVal = "500"; // Checking against 500 as per current logic
		
		WebElement maxi = productPage.setMaximumValue("900");
		try {
			// Using SoftAssert as requested in the code logic
			SoftAssert sa = new SoftAssert();
			sa.assertEquals(maxi.getAttribute("value"), expVal);
			test.log(Status.PASS, "Set Maximum Price Verified Successfully...");
			test.addScreenCaptureFromPath(screenshotUtil.elementScreenShot(maxi, "MaximumValue"));
		} catch (AssertionError e) {
			test.log(Status.FAIL, "Set Maximum Price Failed...");
			test.addScreenCaptureFromPath(screenshotUtil.elementScreenShot(maxi, "MaximumValueFail"));
		}
		Reporter.log("Maximum range value set verified...");
	}

	@Test(priority = 5)
	public void testGoButton() {
		// Clicking the Go button to apply filters
		Assert.assertTrue(productPage.clickGoBtn());
		test = extent.createTest("Go Button Funtionality Test");
		test.log(Status.PASS, "Go button pressed Successfully...");
		test.addScreenCaptureFromPath(screenshotUtil.fullScreenShot(driver, "GoButton"));
		Reporter.log("Filter Applied Successfully...");
	}

	@Test(priority = 6)
	public void printResult() throws InterruptedException, FileNotFoundException, IOException {
		test = extent.createTest("Output Successful");
		
		// Taking a final screenshot and exporting results to Excel
		test.log(Status.PASS, "Output Fetched Successfully...");
		screenshotUtil.fullScreenShot(driver, "FinalOutput");
		productPage.printResult();
		Reporter.log("Output Fetched Successfully...");
	}

	@AfterClass
	public void tearDown() throws InterruptedException {
		// Closing the report, the browser, and the scanner to clean up memory
		extent.flush();
		driver.quit();
		sc.close();
	}

}